{
    "name": "selector-shot-vscode-extension",
    "displayName": "Selector Shot",
    "description": "Show selector screenshots on CodeLens",
    "version": "0.0.2",
    "publisher": "getulionm",
    "engines": {
        "vscode": "^1.90.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished",
        "onCommand:selectorShot.setup",
        "onCommand:selectorShot.refresh",
        "onCommand:selectorShot.openImage",
        "onCommand:selectorShot.enable",
        "onCommand:selectorShot.disable"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "selectorShot.setup",
                "title": "Selector Shot: Setup Project"
            },
            {
                "command": "selectorShot.refresh",
                "title": "Selector Shot: Refresh Index"
            },
            {
                "command": "selectorShot.openImage",
                "title": "Selector Shot: Open Screenshot"
            },
            {
                "command": "selectorShot.enable",
                "title": "Selector Shot: Enable"
            },
            {
                "command": "selectorShot.disable",
                "title": "Selector Shot: Disable"
            }
        ],
        "configuration": {
            "title": "Selector Shot",
            "properties": {
                "selectorShot.dataGlob": {
                    "type": "string",
                    "default": ".selector-shot/**/*.json",
                    "description": "Glob used to discover selector-shot metadata files."
                },
                "selectorShot.onlyCaptured": {
                    "type": "boolean",
                    "default": true,
                    "description": "Prefer CodeLens for successfully captured screenshots; if none exist for a line, fall back to the latest available record."
                },
                "selectorShot.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable Selector Shot CodeLens features for the current workspace."
                }
            }
        }
    },
    "scripts": {
        "build": "node ./scripts/build.mjs",
        "watch": "node ./scripts/build.mjs --watch",
        "package": "npm run build && npx @vscode/vsce package --no-dependencies",
        "test:integration": "npm run build && node ./test/run-integration.js",
        "test:unit": "npm run build && node --test ./test/unit/*.test.js"
    },
    "devDependencies": {
        "@types/node": "^20.12.12",
        "@types/vscode": "^1.90.0",
        "esbuild": "^0.25.0",
        "typescript": "^5.8.2",
        "@vscode/test-electron": "^2.4.1"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/getulionm/selector-shot.git",
        "directory": "packages/vscode-extension"
    }
}
