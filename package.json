{
    "name":  "selector-shot",
    "version":  "0.0.1",
    "private":  true,
    "workspaces":  [
                       "packages/*"
                   ],
    "devDependencies":  {
                            "@playwright/test":  "^1.52.0",
                            "@selector-shot/playwright":  "workspace:*"
                        },
    "scripts":  {
                    "test":  "playwright test",
                    "test:unit":  "node --test packages/playwright-selector-shot/test/*.test.js",
                    "test:extension:unit":  "npm -w selector-shot-vscode-extension run test:unit",
                    "test:all":  "npm run test:unit && npm run test:extension:unit",
                    "build":  "npm -w selector-shot-vscode-extension run build",
                    "watch":  "npm -w selector-shot-vscode-extension run watch",
                    "test:extension":  "npm -w selector-shot-vscode-extension run test:integration",
                    "test:selector-shot-update":  "selector-shot-update"
                }
}
